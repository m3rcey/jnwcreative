# Second Brain Environment Variables

# Database path (optional - defaults to ./data/second-brain.db)
DATABASE_PATH=./data/second-brain.db

# Optional: Slack API credentials for live imports
# SLACK_TOKEN=xoxb-your-token-here
# SLACK_SIGNING_SECRET=your-signing-secret

# Optional: Notion API credentials for live imports
# NOTION_TOKEN=secret_your_token_here
# NOTION_DATABASE_ID=your-database-id
